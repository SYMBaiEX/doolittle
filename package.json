{
  "name": "eliza-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "eliza-agent": "./packages/agent/src/index.ts"
  },
  "packageManager": "bun@1.3.11",
  "description": "Monorepo for the Bun-first ElizaOS-native Eliza Agent platform and vendored official workspace packages.",
  "workspaces": [
    "packages/acp",
    "packages/agent",
    "packages/benchmarks",
    "packages/distributions",
    "packages/modeling",
    "packages/skill-packs-optional",
    "packages/plugins",
    "packages/plugins/*",
    "packages/skills",
    "packages/characters"
  ],
  "scripts": {
    "bootstrap": "bun run scripts/bootstrap.ts",
    "bootstrap:check": "bun run scripts/bootstrap.ts --check",
    "onboard": "bun run scripts/bootstrap.ts",
    "smoke:linked-providers": "bun run scripts/smoke-linked-providers.ts",
    "publish:providers": "bun run scripts/publish-provider-packages.ts",
    "publish:providers:alpha": "bun run publish:providers -- --provider all --publish --tag alpha",
    "install:deps": "bash scripts/install.sh",
    "dev": "bun run --cwd packages/agent dev",
    "start": "bun run --cwd packages/agent start",
    "build": "bun run --cwd packages/agent build",
    "lint": "bunx @biomejs/biome check --write .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "check": "bun run lint:check && bun run typecheck && bun test && bun run build",
    "publish:codex:dry-run": "bun run publish:providers -- --provider codex",
    "publish:claude-code:dry-run": "bun run publish:providers -- --provider claude-code",
    "publish:providers:check": "bun run publish:providers -- --provider all",
    "workspace:list": "find packages -maxdepth 2 -mindepth 1 -type f -name package.json | sort",
    "workspace:plugins": "bun run --cwd packages/agent start --help"
  },
  "dependencies": {
    "@elizaos/agent": "2.0.0-alpha.85",
    "@elizaos/autonomous": "2.0.0-alpha.85",
    "@elizaos/core": "2.0.0-alpha.85",
    "@elizaos/plugin-action-bench": "workspace:*",
    "@elizaos/plugin-agent-orchestrator": "workspace:*",
    "@elizaos/plugin-agent-skills": "workspace:*",
    "@elizaos/plugin-anthropic": "alpha",
    "@elizaos/plugin-autocoder": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-claude-code": "workspace:*",
    "@elizaos/plugin-coding-agent": "workspace:*",
    "@elizaos/plugin-codex": "workspace:*",
    "@elizaos/plugin-cron": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-e2b": "workspace:*",
    "@elizaos/plugin-elizacloud": "alpha",
    "@elizaos/plugin-experience": "workspace:*",
    "@elizaos/plugin-forms": "workspace:*",
    "@elizaos/plugin-knowledge": "workspace:*",
    "@elizaos/plugin-local-embedding": "workspace:*",
    "@elizaos/plugin-mcp": "workspace:*",
    "@elizaos/plugin-openai": "alpha",
    "@elizaos/plugin-pdf": "alpha",
    "@elizaos/plugin-personality": "workspace:*",
    "@elizaos/plugin-planning": "workspace:*",
    "@elizaos/plugin-plugin-manager": "workspace:*",
    "@elizaos/plugin-rolodex": "workspace:*",
    "@elizaos/plugin-shell": "workspace:*",
    "@elizaos/plugin-sql": "alpha",
    "@elizaos/plugin-telegram": "alpha",
    "@elizaos/plugin-trajectory-logger": "workspace:*",
    "@elizaos/plugin-tts": "workspace:*",
    "@elizaos/skills": "2.0.0-alpha.85",
    "@fal-ai/client": "^1.9.4",
    "cron-parser": "^5.2.0",
    "dotenv": "^17.2.3",
    "@eliza-agent/acp": "workspace:*",
    "elizaos": "2.0.0-alpha.85",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@elizaos/agent": "2.0.0-alpha.85",
    "@elizaos/core": "2.0.0-alpha.85",
    "@elizaos/autonomous": "2.0.0-alpha.85",
    "@elizaos/skills": "2.0.0-alpha.85",
    "elizaos": "2.0.0-alpha.85"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@playwright/test": "^1.58.2",
    "@types/blessed": "^0.1.27",
    "@types/node": "^24.6.0",
    "blessed": "^0.1.81",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
