{
  "name": "doolittle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "doolittle": "./packages/agent/src/index.ts"
  },
  "packageManager": "bun@1.3.11",
  "description": "Monorepo for the Bun-first ElizaOS-native Doolittle platform and vendored official workspace packages.",
  "workspaces": [
    "packages/acp",
    "packages/agent",
    "packages/benchmarks",
    "packages/contracts",
    "packages/logger",
    "packages/distributions",
    "packages/modeling",
    "packages/skill-packs-optional",
    "packages/plugins",
    "packages/plugins/*",
    "packages/skills",
    "packages/characters"
  ],
  "scripts": {
    "bootstrap": "bun run scripts/bootstrap.ts",
    "bootstrap:check": "bun run scripts/bootstrap.ts --check",
    "onboard": "bun run scripts/bootstrap.ts",
    "smoke:linked-providers": "bun run scripts/smoke-linked-providers.ts",
    "publish:providers": "bun run scripts/publish-provider-packages.ts",
    "publish:providers:alpha": "bun run publish:providers -- --provider all --publish --tag alpha",
    "install:deps": "bash scripts/install.sh",
    "dev": "bun run --cwd packages/agent dev",
    "start": "bun run --cwd packages/agent start",
    "build": "bun run --cwd packages/agent build",
    "lint": "bunx @biomejs/biome check --write .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "check:repo-hygiene": "bun run scripts/check-repo-hygiene.ts",
    "check:plugin-boundaries": "bun run scripts/check-plugin-boundaries.ts",
    "check:docs-truth": "bun run scripts/sync-doc-truth.ts --check",
    "check:acceptance": "bun run check:repo-hygiene && bun run check:plugin-boundaries && bun run check:docs-truth",
    "check": "bun run lint:check && bun run typecheck && bun test && bun run build",
    "publish:codex:dry-run": "bun run publish:providers -- --provider codex",
    "publish:claude-code:dry-run": "bun run publish:providers -- --provider claude-code",
    "publish:devin:dry-run": "bun run publish:providers -- --provider devin",
    "publish:providers:check": "bun run publish:providers -- --provider all",
    "workspace:list": "find packages -maxdepth 2 -mindepth 1 -type f -name package.json | sort",
    "workspace:plugins": "bun run --cwd packages/agent start --help"
  },
  "dependencies": {
    "@doolittle/acp": "workspace:*",
    "@doolittle/contracts": "workspace:*",
    "@doolittle/logger": "workspace:*",
    "@elizaos/agent": "2.0.0-beta.2",
    "@elizaos/autonomous": "2.0.0-alpha.85",
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/plugin-anthropic": "2.0.0-beta.1",
    "@elizaos/plugin-claude-code": "workspace:*",
    "@elizaos/plugin-codex": "workspace:*",
    "@elizaos/plugin-devin": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-ollama": "2.0.0-beta.1",
    "@elizaos/plugin-openai": "2.0.0-beta.1",
    "@elizaos/plugin-pdf": "2.0.0-beta.1",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/plugin-telegram": "2.0.0-beta.1",
    "@elizaos/skills": "2.0.0-beta.1",
    "@fal-ai/client": "^1.9.4",
    "dotenv": "^17.2.3",
    "elizaos": "2.0.0-beta.5",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@elizaos/agent": "2.0.0-beta.2",
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/autonomous": "2.0.0-alpha.85",
    "@elizaos/skills": "2.0.0-beta.1",
    "elizaos": "2.0.0-beta.5",
    "ollama-ai-provider": "npm:ollama-ai-provider-v2@^3.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@playwright/test": "^1.58.2",
    "@types/blessed": "^0.1.27",
    "@types/node": "^24.6.0",
    "blessed": "^0.1.81",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "patchedDependencies": {
    "@elizaos/plugin-sql@2.0.0-beta.1": "patches/@elizaos%2Fplugin-sql@2.0.0-beta.1.patch"
  }
}
