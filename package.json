{
  "name": "eliza-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "description": "Monorepo for the Bun-first ElizaOS-native Eliza Agent platform and vendored official workspace packages.",
  "workspaces": [
    "packages/agent",
    "packages/plugins",
    "packages/plugins/*",
    "packages/skills",
    "packages/characters"
  ],
  "scripts": {
    "bootstrap": "bun run scripts/bootstrap.ts",
    "bootstrap:check": "bun run scripts/bootstrap.ts --check",
    "install:deps": "bash scripts/install.sh",
    "dev": "bun --watch packages/agent/src/index.ts",
    "start": "bun run packages/agent/src/index.ts",
    "build": "bun build ./packages/agent/src/index.ts --target bun --outdir dist --external sharp",
    "lint": "bunx @biomejs/biome check --write .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint:check && bun run typecheck && bun test && bun run build",
    "workspace:list": "find packages -maxdepth 2 -mindepth 1 -type f -name package.json | sort",
    "workspace:plugins": "bun run packages/agent/src/index.ts --help"
  },
  "dependencies": {
    "@elizaos/agent": "alpha",
    "@elizaos/autonomous": "alpha",
    "@elizaos/core": "alpha",
    "@elizaos/plugin-agent-orchestrator": "workspace:*",
    "@elizaos/plugin-agent-skills": "workspace:*",
    "@elizaos/plugin-anthropic": "alpha",
    "@elizaos/plugin-browser": "alpha",
    "@elizaos/plugin-coding-agent": "workspace:*",
    "@elizaos/plugin-cron": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-experience": "workspace:*",
    "@elizaos/plugin-knowledge": "workspace:*",
    "@elizaos/plugin-local-embedding": "workspace:*",
    "@elizaos/plugin-mcp": "alpha",
    "@elizaos/plugin-openai": "alpha",
    "@elizaos/plugin-pdf": "alpha",
    "@elizaos/plugin-personality": "workspace:*",
    "@elizaos/plugin-plugin-manager": "workspace:*",
    "@elizaos/plugin-rolodex": "workspace:*",
    "@elizaos/plugin-shell": "workspace:*",
    "@elizaos/plugin-sql": "alpha",
    "@elizaos/plugin-telegram": "alpha",
    "@elizaos/plugin-trajectory-logger": "workspace:*",
    "@elizaos/skills": "alpha",
    "cron-parser": "^5.2.0",
    "dotenv": "^17.2.3",
    "elizaos": "alpha",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@elizaos/core": "2.0.0-alpha.85",
    "@elizaos/autonomous": "2.0.0-alpha.85",
    "@elizaos/skills": "2.0.0-alpha.85"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/blessed": "^0.1.27",
    "@types/node": "^24.6.0",
    "blessed": "^0.1.81",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
