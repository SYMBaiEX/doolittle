{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/.doolittle",
      "!!**/.doolittle",
      "!!**/.eliza-agent",
      "!!**/.eliza",
      "!!**/cache",
      "!!**/var",
      "!!**/playwright-report",
      "!!**/test-results",
      "!!skills/generated/index.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
