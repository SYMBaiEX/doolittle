# Core runtime
ELIZA_AGENT_NAME=Eliza Agent
ELIZA_AGENT_MODE=both
ELIZA_AGENT_PORT=3000
ELIZA_AGENT_HOST=0.0.0.0
ELIZA_AGENT_DATA_DIR=.eliza-agent
ELIZA_AGENT_SKILLS_DIR=./skills
ELIZA_AGENT_TIMEZONE=America/Chicago
ELIZA_AGENT_GATEWAY_DATA_DIR=.eliza-agent/gateway
ELIZA_AGENT_HOOKS_DIR=.eliza-agent/hooks
ELIZA_AGENT_WORKSPACE_DIR=.
ELIZA_AGENT_ALLOW_ALL_USERS=false
ELIZA_AGENT_PAIRING_MODE=pair

# Official OpenAI plugin settings.
# Leave unset if you want local offline bootstrap mode or plan to use Anthropic instead.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4
OPENAI_MAX_TOKENS=1200

# Official Anthropic plugin settings.
# Set these if you want Claude-backed execution through the ElizaOS Anthropic plugin.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_SMALL_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_LARGE_MODEL=claude-sonnet-4-20250514

# Persistent memory limits for the two long-lived Eliza Agent stores.
ELIZA_AGENT_MEMORY_CHAR_LIMIT=2200
ELIZA_AGENT_USER_CHAR_LIMIT=1375

# Session search behavior.
ELIZA_AGENT_SESSION_SEARCH_LIMIT=6

# Cron scheduler tick interval in seconds.
ELIZA_AGENT_CRON_TICK_SECONDS=30

# Optional delivery/file outputs for scheduled runs.
ELIZA_AGENT_CRON_OUTPUT_DIR=.eliza-agent/cron-output

# Optional official Telegram plugin settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ROOT=
TELEGRAM_ALLOWED_CHATS=

# Additional transport settings.
DISCORD_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
SIGNAL_SERVICE_URL=
MATRIX_HOMESERVER=

# Execution backend settings.
ELIZA_AGENT_EXECUTION_BACKEND=local
ELIZA_AGENT_DOCKER_IMAGE=oven/bun:latest
ELIZA_AGENT_DOCKER_NETWORK=host
ELIZA_AGENT_DOCKER_WORKSPACE_PATH=/workspace
ELIZA_AGENT_DOCKER_ENV_PASSTHROUGH=PATH,HOME,OPENAI_API_KEY,ANTHROPIC_API_KEY
ELIZA_AGENT_SSH_HOST=
ELIZA_AGENT_SSH_USER=
ELIZA_AGENT_SSH_PATH=
ELIZA_AGENT_SSH_PORT=22
ELIZA_AGENT_SSH_KEY_PATH=
ELIZA_AGENT_SSH_STRICT_HOST_KEY_CHECKING=false

# Optional MCP and future production persistence settings.
MCP_SERVER_COMMAND=
MCP_TIMEOUT_MS=10000
DATABASE_URL=
