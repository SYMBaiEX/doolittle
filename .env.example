# Core runtime
ELIZA_AGENT_NAME=Eliza Agent
ELIZA_AGENT_MODE=both
ELIZA_AGENT_PORT=3000
ELIZA_AGENT_HOST=0.0.0.0
ELIZA_AGENT_DATA_DIR=.eliza-agent
ELIZA_AGENT_SKILLS_DIR=./skills
ELIZA_AGENT_TIMEZONE=America/Chicago
ELIZA_AGENT_GATEWAY_DATA_DIR=.eliza-agent/gateway
ELIZA_AGENT_HOOKS_DIR=.eliza-agent/hooks
ELIZA_AGENT_WORKSPACE_DIR=.
ELIZA_AGENT_ALLOW_ALL_USERS=false
ELIZA_AGENT_PAIRING_MODE=pair

# Official OpenAI plugin settings.
# Leave unset if you want local offline bootstrap mode or plan to use Anthropic instead.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=
OPENAI_TEMPERATURE=0.4
OPENAI_MAX_TOKENS=1200

# Official Anthropic plugin settings.
# Set these if you want Claude-backed execution through the ElizaOS Anthropic plugin.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_SETUP_TOKEN=
ELIZA_AGENT_CLAUDE_CODE_CLI_FALLBACK=false
ANTHROPIC_BASE_URL=
ANTHROPIC_SMALL_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_LARGE_MODEL=claude-sonnet-4-20250514

# Official autocoder / E2B ecosystem settings.
# E2B defaults to local mode at runtime unless you override it here.
E2B_MODE=local
E2B_API_KEY=
E2B_BASE_URL=
GITHUB_TOKEN=

# Persistent memory limits for the two long-lived Eliza Agent stores.
ELIZA_AGENT_MEMORY_CHAR_LIMIT=2200
ELIZA_AGENT_USER_CHAR_LIMIT=1375

# Session search behavior.
ELIZA_AGENT_SESSION_SEARCH_LIMIT=6

# Cron scheduler tick interval in seconds.
ELIZA_AGENT_CRON_TICK_SECONDS=30

# Optional delivery/file outputs for scheduled runs.
ELIZA_AGENT_CRON_OUTPUT_DIR=.eliza-agent/cron-output

# Optional official Telegram plugin settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ROOT=
TELEGRAM_ALLOWED_CHATS=

# Additional transport settings.
DISCORD_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
SIGNAL_CLI_COMMAND=
MATRIX_HOMESERVER=
MATRIX_ACCESS_TOKEN=
EMAIL_SEND_COMMAND=
FAL_API_KEY=
SMS_SEND_COMMAND=
MATTERMOST_URL=
MATTERMOST_TOKEN=
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=
DINGTALK_WEBHOOK_URL=
DINGTALK_ACCESS_TOKEN=

# Browser automation settings.
# Lightpanda is the default browser backend, with automatic fallback to basic HTTP mode if unavailable.
ELIZA_AGENT_BROWSER_PROVIDER=lightpanda
ELIZA_AGENT_BROWSER_COMMAND=lightpanda
ELIZA_AGENT_BROWSER_CDP_URL=
ELIZA_AGENT_BROWSER_OBEY_ROBOTS=true

# Execution backend settings. Supported values: local, docker, podman, ssh, singularity, daytona, modal.
ELIZA_AGENT_EXECUTION_BACKEND=local
ELIZA_AGENT_EXECUTION_COMMAND_TIMEOUT_MS=30000
ELIZA_AGENT_EXECUTION_HEALTH_TIMEOUT_MS=5000
ELIZA_AGENT_CONTAINER_CPU_LIMIT=2
ELIZA_AGENT_CONTAINER_MEMORY_LIMIT=2g
ELIZA_AGENT_CONTAINER_PIDS_LIMIT=256
ELIZA_AGENT_CONTAINER_READ_ONLY_ROOT=true
ELIZA_AGENT_DOCKER_IMAGE=oven/bun:latest
ELIZA_AGENT_DOCKER_NETWORK=host
ELIZA_AGENT_DOCKER_WORKSPACE_PATH=/workspace
ELIZA_AGENT_DOCKER_ENV_PASSTHROUGH=PATH,HOME,OPENAI_API_KEY,ANTHROPIC_API_KEY
ELIZA_AGENT_SINGULARITY_IMAGE=
ELIZA_AGENT_DAYTONA_TARGET=
ELIZA_AGENT_DAYTONA_COMMAND=
ELIZA_AGENT_DAYTONA_SHELL=/bin/sh
ELIZA_AGENT_DAYTONA_WORKSPACE_PATH=/workspace
ELIZA_AGENT_DAYTONA_SNAPSHOT=
ELIZA_AGENT_DAYTONA_BOOTSTRAP_COMMAND=
ELIZA_AGENT_DAYTONA_STATUS_COMMAND=
ELIZA_AGENT_DAYTONA_INSPECT_COMMAND=
ELIZA_AGENT_MODAL_TARGET=
ELIZA_AGENT_MODAL_COMMAND=
ELIZA_AGENT_MODAL_SHELL=/bin/bash
ELIZA_AGENT_MODAL_WORKSPACE_PATH=/workspace
ELIZA_AGENT_MODAL_ENVIRONMENT=
ELIZA_AGENT_MODAL_BOOTSTRAP_COMMAND=
ELIZA_AGENT_MODAL_STATUS_COMMAND=
ELIZA_AGENT_MODAL_INSPECT_COMMAND=
ELIZA_AGENT_REMOTE_SYNC_MODE=mirror
ELIZA_AGENT_REMOTE_SYNC_INCLUDE=**/*
ELIZA_AGENT_REMOTE_SYNC_EXCLUDE=.git,.eliza-agent,node_modules,dist,coverage,.cache,.turbo,.DS_Store
ELIZA_AGENT_REMOTE_ARTIFACT_PATHS=.eliza-agent/remote-artifacts,.eliza-agent/trajectories,.eliza-agent/cron-output
ELIZA_AGENT_REMOTE_ARTIFACT_POLICY=metadata-only
ELIZA_AGENT_REMOTE_WORKSPACE_LABEL=eliza-agent-workspace
ELIZA_AGENT_SSH_HOST=
ELIZA_AGENT_SSH_USER=
ELIZA_AGENT_SSH_PATH=
ELIZA_AGENT_SSH_PORT=22
ELIZA_AGENT_SSH_KEY_PATH=
ELIZA_AGENT_SSH_STRICT_HOST_KEY_CHECKING=false

# Optional MCP and future production persistence settings.
MCP_SERVER_COMMAND=
MCP_TIMEOUT_MS=10000
ACP_SERVER_COMMAND=
ACP_TIMEOUT_MS=10000
DATABASE_URL=
