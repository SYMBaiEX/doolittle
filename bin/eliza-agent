#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
cd "$ROOT"

if ! command -v bun >/dev/null 2>&1; then
  echo "Eliza Agent requires Bun. Install Bun first, then rerun."
  exit 1
fi

show_boot_splash() {
  if [[ "${ELIZA_AGENT_SKIP_SPLASH:-0}" == "1" ]]; then
    return
  fi
  if [[ ! -t 0 || ! -t 1 ]]; then
    return
  fi

  local orange=$'\033[38;2;255;106;0m'
  local cyan=$'\033[38;2;85;214;255m'
  local dim=$'\033[2m'
  local bold=$'\033[1m'
  local reset=$'\033[0m'

  trap 'printf "\033[?25h"' EXIT
  printf '\033[?25l'
  printf '\033[2J\033[H'
  printf "%s\n" \
"${orange}${bold}███████╗██╗     ██╗███████╗ █████╗  ██████╗ ███████╗${reset}" \
"${orange}${bold}██╔════╝██║     ██║╚══███╔╝██╔══██╗██╔═══██╗██╔════╝${reset}" \
"${orange}${bold}█████╗  ██║     ██║  ███╔╝ ███████║██║   ██║███████╗${reset}" \
"${orange}${bold}██╔══╝  ██║     ██║ ███╔╝  ██╔══██║██║   ██║╚════██║${reset}" \
"${orange}${bold}███████╗███████╗██║███████╗██║  ██║╚██████╔╝███████║${reset}" \
"${orange}${bold}╚══════╝╚══════╝╚═╝╚══════╝╚═╝  ╚═╝ ╚═════╝ ╚══════╝${reset}"
  printf "\n%s\n" "${cyan}${bold}ELIZA AGENT // CYPHERPUNK OPERATOR SHELL${reset}"
  printf "%s\n" "${dim}Booting workspace, linking native plugins, and warming the local shell...${reset}"
  sleep 1.8
  printf '\033[2J\033[H'
  printf '\033[?25h'
  trap - EXIT
}

load_local_runtime_env() {
  export PGLITE_DATA_DIR="${PGLITE_DATA_DIR:-$ROOT/.eliza-agent/pglite}"
  mkdir -p "$PGLITE_DATA_DIR"

  local env_file="$ROOT/.env"
  if [[ -f "$env_file" ]]; then
    if ! grep -Eq '^[[:space:]]*(DATABASE_URL|POSTGRES_URL)=' "$env_file"; then
      unset DATABASE_URL || true
      unset POSTGRES_URL || true
    fi
  else
    unset DATABASE_URL || true
    unset POSTGRES_URL || true
  fi
}

ensure_onboarded() {
  if [[ ! -f "$ROOT/.eliza-agent/onboarding.json" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      echo "No onboarding state found. Beginning first contact so I can finish setup."
      bun run scripts/bootstrap.ts
    else
      echo "No onboarding state found. Run 'eliza-agent setup' to finish onboarding, or 'eliza-agent doctor' to inspect readiness first."
      exit 1
    fi
  fi
}

command_name="${1:-start}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command_name" in
  start)
    ensure_onboarded
    load_local_runtime_env
    show_boot_splash
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" src/index.ts --cli "$@"
    ;;
  setup|onboard|bootstrap)
    exec bun run "$ROOT/scripts/bootstrap.ts" "$@"
    ;;
  install)
    exec bash "$ROOT/scripts/install.sh" "$@"
    ;;
  doctor|check)
    exec bun run "$ROOT/scripts/bootstrap.ts" --check "$@"
    ;;
  dev)
    ensure_onboarded
    load_local_runtime_env
    show_boot_splash
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" dev "$@"
    ;;
  api)
    ensure_onboarded
    load_local_runtime_env
    exec bun run --cwd "$ROOT/packages/agent" src/index.ts --api-only "$@"
    ;;
  gateway)
    ensure_onboarded
    load_local_runtime_env
    exec bun run --cwd "$ROOT/packages/agent" src/index.ts --gateway "$@"
    ;;
  plain|plain-cli)
    ensure_onboarded
    load_local_runtime_env
    show_boot_splash
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" src/index.ts --plain-cli "$@"
    ;;
  *)
    ensure_onboarded
    load_local_runtime_env
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" src/index.ts "$command_name" "$@"
    ;;
esac
