#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
cd "$ROOT"

if ! command -v bun >/dev/null 2>&1; then
  echo "Eliza Agent requires Bun. Install Bun first, then rerun."
  exit 1
fi

load_local_runtime_env() {
  export PGLITE_DATA_DIR="${PGLITE_DATA_DIR:-$ROOT/.eliza-agent/pglite}"
  mkdir -p "$PGLITE_DATA_DIR"

  local env_file="$ROOT/.env"
  if [[ -f "$env_file" ]]; then
    if ! grep -Eq '^[[:space:]]*(DATABASE_URL|POSTGRES_URL)=' "$env_file"; then
      unset DATABASE_URL || true
      unset POSTGRES_URL || true
    fi
  else
    unset DATABASE_URL || true
    unset POSTGRES_URL || true
  fi
}

ensure_onboarded() {
  if [[ ! -f "$ROOT/.eliza-agent/onboarding.json" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      echo "No onboarding state found. Beginning first contact..."
      bun run scripts/bootstrap.ts
    else
      echo "No onboarding state found. Run 'eliza-agent setup' first."
      exit 1
    fi
  fi
}

command_name="${1:-start}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command_name" in
  start)
    ensure_onboarded
    load_local_runtime_env
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" src/index.ts --cli "$@"
    ;;
  setup|onboard|bootstrap)
    exec bun run "$ROOT/scripts/bootstrap.ts" "$@"
    ;;
  install)
    exec bash "$ROOT/scripts/install.sh" "$@"
    ;;
  doctor|check)
    exec bun run "$ROOT/scripts/bootstrap.ts" --check "$@"
    ;;
  dev)
    ensure_onboarded
    load_local_runtime_env
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" dev "$@"
    ;;
  api)
    ensure_onboarded
    load_local_runtime_env
    exec bun run --cwd "$ROOT/packages/agent" src/index.ts --api-only "$@"
    ;;
  gateway)
    ensure_onboarded
    load_local_runtime_env
    exec bun run --cwd "$ROOT/packages/agent" src/index.ts --gateway "$@"
    ;;
  plain|plain-cli)
    ensure_onboarded
    load_local_runtime_env
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" src/index.ts --plain-cli "$@"
    ;;
  *)
    ensure_onboarded
    load_local_runtime_env
    ELIZA_AGENT_MODE=cli exec bun run --cwd "$ROOT/packages/agent" src/index.ts "$command_name" "$@"
    ;;
esac
