{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/agent/src/*"],
      "@eliza-agent/acp": ["packages/acp/src/index.ts"],
      "@plugins/*": ["packages/plugins/*"],
      "@characters/*": ["packages/characters/*"]
    }
  },
  "include": [
    "packages/agent/src/**/*.ts",
    "packages/agent/src/**/*.d.ts",
    "packages/characters/**/*.json",
    "packages/**/*.ts"
  ]
}
