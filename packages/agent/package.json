{
  "name": "@doolittle/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Primary Doolittle application package.",
  "dependencies": {
    "@doolittle/acp": "workspace:*",
    "@doolittle/contracts": "workspace:*",
    "@doolittle/logger": "workspace:*",
    "@elizaos/agent": "2.0.0-beta.2"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --target bun --outdir ../../dist --external sharp --external '@elizaos/*'"
  }
}
